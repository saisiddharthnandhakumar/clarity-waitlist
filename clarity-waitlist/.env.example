# ── Clarity — Environment Variables ──
# Copy this file to .env.local and fill in your values.

# Supabase
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for OG metadata)
NEXT_PUBLIC_SITE_URL=https://getclarity.app

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog
# Get these from your PostHog project dashboard: Settings > Project Settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_posthog_project_token
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
